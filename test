Update your helper in generate.py

Make the helper accept the full argument set used in the tests.

def maybe_turboquant_k_cache(
    prompt_cache,
    turboquant_k_start,
    turboquant_main_bits,
    turboquant_group_size,
    turboquant_rotation,
    turboquant_return_mode,
    turboquant_resid_scale_bits,
    turboquant_v_bits,
    turboquant_v_group_size,
    turboquant_v_enabled,
):
    if turboquant_k_start is None:
        return

    for e, c in enumerate(prompt_cache):
        if isinstance(c, TurboQuantKCache):
            continue

        if hasattr(c, "to_turboquant") and c.offset >= turboquant_k_start:
            prompt_cache[e] = c.to_turboquant(
                main_bits=turboquant_main_bits,
                group_size=turboquant_group_size,
                rotation=turboquant_rotation,
                return_mode=turboquant_return_mode,
                resid_scale_bits=turboquant_resid_scale_bits,
                v_bits=turboquant_v_bits,
                v_group_size=turboquant_v_group_size,
                v_enabled=turboquant_v_enabled,
            )

That isinstance(c, TurboQuantKCache) guard matters. Without it, repeated calls during generation can keep rebuilding the cache object.

